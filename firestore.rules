rules_version = '2';

// ShipVa — deny-by-default. All writes that carry business rules go
// through Cloud Functions (admin SDK bypasses these rules). Clients get
// scoped reads + a few self-service writes only.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isStaff() { return signedIn() && role() in ['super_admin', 'admin', 'dispatcher', 'support']; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    // Users — readable by self or staff; role/claims set only by backend.
    match /users/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow write: if false;
    }

    // Customer profile — self or staff read; self may edit saved addresses.
    match /customers/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow create, update: if isSelf(uid);
      allow delete: if false;
    }

    // Drivers — staff read all; a driver reads own doc. Verification via backend.
    match /drivers/{uid} {
      allow read: if isSelf(uid) || isStaff();
      allow write: if false;
    }

    // Bookings — customer sees own; assigned driver sees theirs; staff see all.
    // All mutations go through callables, so client writes are denied.
    match /bookings/{id} {
      allow read: if isStaff()
        || (signedIn() && resource.data.customerId == request.auth.uid)
        || (signedIn() && resource.data.assignedDriverId == request.auth.uid);
      allow write: if false;
    }

    // Bids — staff and the bidding driver; written by callables.
    match /bids/{id} {
      allow read: if isStaff() || (signedIn() && resource.data.bidderId == request.auth.uid);
      allow write: if false;
    }

    // Transporter exchange — verified members + staff read; writes via backend.
    match /transporters/{id}     { allow read: if signedIn(); allow write: if false; }
    match /fleetVehicles/{id}     { allow read: if signedIn(); allow write: if false; }
    match /fleetDrivers/{id}      { allow read: if signedIn(); allow write: if false; }
    match /loadPosts/{id}         { allow read: if signedIn(); allow write: if false; }
    match /truckPosts/{id}        { allow read: if signedIn(); allow write: if false; }
    match /connections/{id} {
      allow read: if isStaff()
        || (signedIn() && (resource.data.partyA == request.auth.uid || resource.data.partyB == request.auth.uid));
      allow write: if false;
    }

    // ── Transporter OS (partner-web) team ─────────────────────────────────
    // Team members carry their own role + page permissions. The bootstrap owner
    // email may self-create its owner doc on first sign-in; everyone else is
    // provisioned by an admin. Members can edit their own profile but not their
    // own role/pages (no self-escalation).
    function orgMember() { return get(/databases/$(database)/documents/orgMembers/$(request.auth.uid)).data; }
    function isOrgMember() { return signedIn() && exists(/databases/$(database)/documents/orgMembers/$(request.auth.uid)); }
    function isOrgAdmin() { return isOrgMember() && orgMember().role in ['owner', 'manager']; }
    function isOrgTeamLeader() { return isOrgMember() && orgMember().role == 'team_leader'; }
    function isBootstrapOwner() { return signedIn() && request.auth.token.email == 'admin@sarvaexpress.in'; }
    // Who may destroy records: leadership only (owner, manager, team leader).
    // Mirrors canEditRecords in lib/roles.tsx — keep the two in step.
    function canWipe() { return isOrgAdmin() || isOrgTeamLeader(); }

    match /orgMembers/{uid} {
      allow read: if isOrgMember() || isBootstrapOwner();
      // Owner/manager create anyone; the bootstrap owner self-creates; a Team
      // Leader may create POCs (supervisor/accountant) under themselves.
      allow create: if isOrgAdmin()
        || (isSelf(uid) && isBootstrapOwner())
        || (isOrgTeamLeader()
            && request.resource.data.leaderUid == request.auth.uid
            && request.resource.data.role in ['supervisor', 'accountant']);
      // Admin edits anyone; a member edits their own profile (not role/pages); a
      // Team Leader edits their POCs but can't move them out or elevate them.
      allow update: if isOrgAdmin()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.pages == resource.data.pages)
        || (isOrgTeamLeader()
            && resource.data.leaderUid == request.auth.uid
            && request.resource.data.leaderUid == resource.data.leaderUid
            && request.resource.data.role in ['supervisor', 'accountant']);
      allow delete: if isOrgAdmin();
    }

    // Assigned tasks — admins manage; an assignee may update their own (status/timer).
    match /orgTasks/{id} {
      allow read: if isOrgMember();
      allow create: if isOrgAdmin();
      allow update: if isOrgAdmin() || (isOrgMember() && resource.data.assigneeUid == request.auth.uid);
      allow delete: if isOrgAdmin();
    }

    // Activity/session logs — each member writes their own; admins read all.
    match /orgActivity/{id} {
      allow read: if isOrgMember();
      allow create: if isOrgMember() && request.resource.data.uid == request.auth.uid;
      allow update: if isOrgMember() && resource.data.uid == request.auth.uid;
      allow delete: if isOrgAdmin();
    }

    // Work log — each member appends their own entries; the team can read them.
    match /orgWorklog/{id} {
      allow read: if isOrgMember();
      allow create: if isOrgMember() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOrgAdmin();
    }

    // Trips — POC-scoped with a Team-Leader layer. Owner/manager see & manage
    // everything; a POC sees trips they own (ownerUid); a Team Leader sees the
    // whole team (leaderUid == them).
    match /orgTrips/{id} {
      allow read: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
      allow create: if isOrgAdmin() || (isOrgMember() && (request.resource.data.ownerUid == request.auth.uid || request.resource.data.leaderUid == request.auth.uid));
      allow update: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
      allow delete: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
    }

    // Amazon tours — same POC + Team-Leader scoping as trips.
    match /orgTours/{id} {
      allow read: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
      allow create: if isOrgAdmin() || (isOrgMember() && (request.resource.data.ownerUid == request.auth.uid || request.resource.data.leaderUid == request.auth.uid));
      allow update: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
      allow delete: if isOrgAdmin() || (isOrgMember() && (resource.data.ownerUid == request.auth.uid || resource.data.leaderUid == request.auth.uid));
    }

    // VRID registry — company-wide uniqueness. Any member may look one up or
    // claim a new one (create fails if it already exists). Releasing is
    // leadership only, and must match who can delete a tour: deleting a tour
    // frees its VRIDs, so a team leader who can do one must be able to do the
    // other — otherwise the VRID stays claimed by a route that no longer exists.
    match /orgVrids/{vrid} {
      allow read: if isOrgMember();
      allow create: if isOrgMember();
      allow update: if false;
      allow delete: if canWipe();
    }

    // Shared reference data — customers, drivers, trucks and truck owners. Common
    // to the whole org: any member may read and add/edit (so a supervisor's new
    // customer or driver is visible to everyone, and a POC can still attach the
    // documents they collect). Deleting is leadership only — owner, manager or
    // team leader — matching canEditRecords in lib/roles.
    match /orgCustomers/{id} { allow read, create, update: if isOrgMember(); allow delete: if canWipe(); }
    match /orgDrivers/{id}   { allow read, create, update: if isOrgMember(); allow delete: if canWipe(); }
    match /orgTrucks/{id}    { allow read, create, update: if isOrgMember(); allow delete: if canWipe(); }
    match /orgOwners/{id}    { allow read, create, update: if isOrgMember(); allow delete: if canWipe(); }

    // Delay reason codes — the client's rule: the admin sets the list, everyone
    // else may only pick from it. So reads are open to members, writes aren't.
    match /orgReasonCodes/{id} {
      allow read: if isOrgMember();
      allow create, update, delete: if isOrgAdmin();
    }

    // Public config (vehicle types, zones, fares) — readable by any signed-in user.
    match /config/{doc} { allow read: if signedIn(); allow write: if false; }

    // Everything else (auditLogs, counters, notifications) — backend only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
