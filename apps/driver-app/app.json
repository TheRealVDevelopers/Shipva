{
  "expo": {
    "name": "ShipVa Driver",
    "slug": "shipva-driver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "gndriver",
    "splash": {
      "backgroundColor": "#0F3D72"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.shipva.driver",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ShipVa needs your location to alert you to nearby jobs and track active trips.",
        "NSLocationWhenInUseUsageDescription": "ShipVa needs your location to alert you to nearby jobs and track active trips.",
        "NSCameraUsageDescription": "ShipVa needs the camera for delivery proof photos.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "in.shipva.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": ["expo-camera", "expo-location", "expo-notifications", "expo-secure-store"],
    "extra": {
      "firebaseProjectId": "sarvaexpressos"
    }
  }
}
