{
  "name": "ground-network",
  "version": "0.1.0",
  "private": true,
  "description": "Ground Network — on-demand + auction + transporter-exchange logistics marketplace for Bangalore. See README.md.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "emulators": "firebase emulators:start",
    "dev:admin": "npm run dev -w @ground/admin-web",
    "dev:driver": "npm run start -w @ground/driver-app",
    "build:functions": "npm run build -w functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage,database",
    "deploy:functions": "firebase deploy --only functions"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
